{
  "name": "gng-calculator",
  "version": "1.0.0",
  "description": "",
  "main": "src/client/main.tsx",
  "scripts": {
    "build": "vite build",
    "build:client": "vite build",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:api": "API_RELOAD=1 .venv/bin/python -m src.server.main",
    "start": "API_HOST=0.0.0.0 .venv/bin/python -m src.server.main",
    "test": "node scripts/run-ts-tests.mjs",
    "balances:update": "python3 scripts/get-balances.py",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "Darren R. Skidmore",
  "license": "MIT",
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@vitejs/plugin-react": "^6.0.3",
    "bootstrap": "^5.3.2",
    "concurrently": "^10.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.9.4",
    "typescript": "^7.0.2"
  }
}
